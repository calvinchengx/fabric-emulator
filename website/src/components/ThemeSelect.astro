---
// Starlight's header theme select, with the parity version picker beside it.
// Overriding ThemeSelect is the light-touch way to add a control to the top
// nav: Starlight's Header has no slot, and copying Header.astro wholesale would
// fork its layout and drift on upgrade. The picker renders itself only on the
// parity pages, so every other page gets the stock header.
//
// Note: the header's right group is `sl-hidden md:sl-flex`, so this (like the
// theme select itself) appears at >=50rem. Narrower screens reach the versions
// via the Parity history index page.
import Default from '@astrojs/starlight/components/ThemeSelect.astro';
import ParityVersionPicker from './ParityVersionPicker.astro';
---

<ParityVersionPicker />
<Default><slot /></Default>
